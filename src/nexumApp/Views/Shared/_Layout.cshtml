<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Nexum</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/nexumApp.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">Nexum</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex align-items-center w-100">

                    <!--BARRA DE PESQUISA NO MEIO-->
                    <form class="search-wrapper mx-auto"
                          method="get"
                          asp-area=""
                          asp-controller="Home"
                          asp-action="Marketplace">

                        <input type="text"
                               class="search-input"
                               name="search"
                               placeholder="Buscar ONGs, vagas, metas..."
                               value="@Context.Request.Query["search"]" />

                        <button type="submit" class="search-btn">
                            <i class="bi bi-search"></i>
                        </button>
                    </form>

                    <!--MENU À DIREITA-->
                    <ul class="navbar-nav ms-sm-auto me-0">
                        
                        <li class="nav-item">
                            @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Admin"))
                            {
                                <a class="nav-link"
                                   asp-area="Admin"
                                   asp-controller="Dashboard"
                                   asp-action="Index">
                                    Home
                                </a>
                            }
                            else
                            {
                                <a class="nav-link"
                                   asp-area=""
                                   asp-controller="Home"
                                   asp-action="SmartRedirect">
                                    Home
                                </a>
                            }
                        </li>

                        @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-area=""
                                   asp-controller="Home"
                                   asp-action="Index">
                                    Marketplace
                                </a>
                            </li>
                        }

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="sobreNosMenu"
                               role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Sobre nós
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="sobreNosMenu">
                                <li><a class="dropdown-item" asp-controller="Home" asp-action="QuemSomos" asp-area="">Quem somos</a></li>
                                <li><a class="dropdown-item" asp-controller="FaleConosco" asp-action="Index" asp-area="">Fale conosco</a></li>
                            </ul>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="About">Sobre</a>
                        </li>
                        <li>
                            <a class="nav-link text-dark" asp-controller="Ongs" asp-action="Index">ONGs</a>
                        </li>
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2025 - Nexum - <a asp-area="" asp-controller="Home" asp-action="About">Sobre</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

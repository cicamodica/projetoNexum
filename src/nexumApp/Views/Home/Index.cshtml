
@using nexumApp.Models
@model IEnumerable<nexumApp.Models.Meta>
@{
    ViewData["Title"] = "Marketplace";
    var pendingValues = ViewBag.PendingValues as Dictionary<int, int> ?? new Dictionary<int, int>();
    string search = ViewBag.Search as string;
    var vagas = ViewBag.Vagas as List<nexumApp.Models.Vaga>;
    var ongs = ViewBag.Ongs as List<nexumApp.Models.Ong>;
    var selectedTags = ViewBag.SelectedTags as List<int> ?? new List<int>();
    var tagsModel = new nexumApp.Models.Tags();
    var tab = Context.Request.Query["tab"].ToString();
}
<link rel="stylesheet" href="~/css/home.css" />

@if (!string.IsNullOrWhiteSpace(search))
{
    <h3 class="mt-4">Resultados para "@search"</h3>

    //ONGs
    if (ongs != null && ongs.Any())
    {
        <h4 class="mt-3">ONGs encontradas (@ongs.Count)</h4>
        <div class="row">
            @foreach (var o in ongs)
            {
                <div class="col-md-4 mb-3">
                    <div class="card p-3 shadow-sm">
                        <h5>@o.Nome</h5>
                        <p>@o.Endereço</p>
                        <p><small>CNPJ: @o.CNPJ</small></p>
                        <a asp-controller="Ongs"
                           asp-action="Details"
                           asp-route-id="@o.Id"
                           class="btn btn-primary">
                            Ver ONG
                        </a>
                    </div>
                </div>
            }
        </div>
    }

    //VAGAS
    if (vagas != null && vagas.Any())
    {
        <h4 class="mt-4">Vagas encontradas (@vagas.Count)</h4>
        <div class="row">
            @foreach (var v in vagas)
            {
                <div class="col-md-4 mb-3">
                    <div class="card p-3 shadow-sm">
                        <h5>@v.Titulo</h5>
                        <p>@v.Descricao</p>
                        <a asp-controller="Vagas"
                           asp-action="Details"
                           asp-route-id="@v.IdVaga"
                           class="btn btn-outline-primary">
                            Ver vaga
                        </a>
                    </div>
                </div>
            }
        </div>
    }

    <h4 class="mt-4">Metas encontradas (@Model.Count())</h4>
}


<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<div class="header-banner">
    <div class="header-banner-overlay">
        <div class="header-text">
            <h1>NEXUM</h1>
            <p>CONECTANDO PESSOAS,<br>FORTALECENDO CAUSAS</p>
        </div>
    </div>
</div>

<div class="container">

    <div class="page-container">


        <aside class="sidebar">
            <h5>O que você procura?</h5>
            <div class="btn-toggle-group">
                <button id="btn-toggle-doacoes" class="btn btn-toggle active">Doações</button>
                <button id="btn-toggle-voluntariado" class="btn btn-toggle">Voluntariado</button>
            </div>

            <div class="filter-section">
                <div class="filter-section mt-4">
                    <h6>Causas</h6>
                    <div class="filter-tags d-flex flex-wrap gap-2">
                        @for (int index = 0 ; index < tagsModel.TagsNames.Count ; index++)
                        {
                            @* var isActive = selectedTags.Contains(int.Parse(tag.Value)); *@
                            <button type="button" class="btn-tag" id="@index" onclick="toggleTag(this)">
                                @tagsModel.TagsNames[index]
                            </button>
                        }
                    </div>
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="radio" name="filtroEndereco" id="radioEndereco" onclick="toggleLocationInputs(true)">
                    <label class="form-check-label" for="radioEndereco">
                        Endereço
                    </label>
                </div>

                <div id="location-inputs" class="filter-location-inputs" style="display:none;">
                    <input type="text" id="cep-input" class="form-control" placeholder="CEP" maxlength="9">
                           
                </div>

                <button id="btn-filtrar" class="btn btn-filtrar">Filtrar</button>



            </div>
        </aside>


        <main class="main-content">

            <h4 id="resultados-titulo">Resultados para Doações (@Model.Count())</h4>


            <div id="metas-container">
                <div class="row">
        @if (Model.Any())
        {
            foreach (var meta in Model)
            {

                <div class="col-md-6 col-lg-4 mb-4 card-item-meta">
                    <div class="meta-card-design">
                        <div>

                            @if (!string.IsNullOrEmpty(meta.ImagemUrl))
                            {
                                <img src="@meta.ImagemUrl" asp-append-version="true" 
                                     class="card-img-top mb-3"
                                     style="border-radius: 15px; height: 180px; object-fit: cover;" 
                                     alt="@meta.Recurso">
                            }

                            <h5 class="card-title-public">@meta.Recurso</h5>
                            <p class="card-ong-name">@meta.Ong.Nome</p>
                            <p class="card-text-public">@meta.Descricao</p>

                                        <div class="location-info mt-2">
                                            <i class="bi bi-geo-alt-fill"></i>
                                            @if (meta.Filial != null)
                                            {
                                                <span>@meta.Filial.Endereço</span>
                                            }
                                            else
                                            {
                                                <span>@meta.Ong.Endereço</span>
                                            }
                                        </div>

                                        @{
                                            // Lógica de cálculo da barra
                                            var valorConfirmado = (double)meta.ValorAtual;
                                            var valorAlvo = (double)meta.ValorAlvo;

                                            // Acessa o dicionário de valores pendentes
                                            var pendingData = (Dictionary<int, int>)ViewBag.PendingValues;

                                            // Calcula o valor pendente (declarado uma única vez)
                                            var valorPendente = (double)(pendingData.ContainsKey(meta.Id) ? pendingData[meta.Id] : 0);

                                            // Cálculos de porcentagem
                                            var percConfirmado = (valorAlvo > 0) ? (valorConfirmado / valorAlvo) * 100 : 0;
                                            var percPendente = (valorAlvo > 0) ? (valorPendente / valorAlvo) * 100 : 0;

                                            // Garante que a barra não passe de 100%
                                            if (percConfirmado + percPendente > 100)
                                            {
                                                percPendente = 100 - percConfirmado;
                                            }

                                            var progressoConfirmadoF = percConfirmado.ToString("F0");
                                            var progressoPendenteF = percPendente.ToString("F0");
                                        }

                                        <div class="mb-2 mt-3">
                                            <small class="text-muted">Progresso: @meta.ValorAtual de @meta.ValorAlvo</small>

                                            @if (valorPendente > 0)
                                            {
                                                <small class="text-muted d-block">(@valorPendente pendentes de aprovação)</small>
                                            }

                                            <div class="progress" style="height: 20px;">
                                                <div class="progress-bar" role="progressbar"
                                                     style="width: @(progressoConfirmadoF)%;"
                                                     aria-valuenow="@progressoConfirmadoF"
                                                     aria-valuemin="0"
                                                     aria-valuemax="100">
                                                    @(progressoConfirmadoF)%
                                                </div>
                                                <div class="progress-bar progress-bar-striped bg-info" role="progressbar"
                                                     style="width: @(progressoPendenteF)%;"
                                                     aria-valuenow="@progressoPendenteF"
                                                     aria-valuemin="0"
                                                     aria-valuemax="100">
                                                </div>
                                            </div>
                                        </div>

                            @if (meta.DataFim.HasValue)
                            {
                                <p class="small text-muted mt-2 mb-2 text-center">
                                    Encerra em: @meta.DataFim.Value.ToString("dd/MM/yyyy")
                                </p>
                            }
                        </div>

                        <div class="mt-3">

                            <!-- BOTÃO DOAR COM OS DADOS NECESSÁRIOS -->
                            <a href="#" class="btn btn-doar abrirModalDoacaoBtn"
                               data-meta-id="@meta.Id"
                               data-titulo="@meta.Recurso"
                               data-ong="@meta.Ong.Nome"
                               data-descricao="@meta.Descricao"
                               data-endereco="@(meta.Filial != null ? meta.Filial.Endereço : meta.Ong.Endereço)"
                               data-atual="@meta.ValorAtual"
                               data-alvo="@meta.ValorAlvo"
                               data-imagem="@meta.ImagemUrl"
                               data-ong-cnpj="@meta.Ong.CNPJ"
                               data-bs-toggle="modal"
                               data-bs-target="#modalDoacao">
                                            
                                Doar
                            </a>

                        </div>
                    </div>
                </div>

            }
        }
        else
        {
            <div class="col-12 text-center">
                <p class="lead">Nenhuma meta ativa encontrada no momento.</p>
            </div>
        }
    </div>
            



       

                
</div>


            <div id="vagas-container" style="display:none;">
                <div class="row">

                    <div class="col-12 text-center">
                        <p class="lead">Buscando vagas...</p>
                    </div>
                </div>
            </div>

        </main>

    </div>
</div>

<div class="modal fade" id="vagaModal" tabindex="-1" aria-labelledby="vagaModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content modal-vaga-content">
            <div class="modal-header modal-vaga-header">
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close" style="position: absolute; top: 1.5rem; right: 1.5rem;"></button>
            </div>
            <div class="modal-body modal-vaga-body" id="vagaModalBody">
                
                <div class="text-center p-4">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Carregando...</span>
                    </div>
                    <p class="mt-2">Carregando...</p>
                </div>
            </div>
        </div>
    </div>
</div>
<div class="modal fade" id="modalDoacao" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius: 15px;">
            <div class="modal-header">
                <h5 class="modal-title">INFORMAÇÕES SOBRE A META</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <div class="d-flex align-items-start">

                    <!-- IMAGEM -->
                    <img id="modalDoacaoLogo"
                         src=""
                         class="me-3"
                         style="width: 60px; height: 60px; border-radius: 50%; object-fit: cover;">

                    <div class="w-100">

                        <!-- TÍTULO -->
                        <h5 id="modalDoacaoTitulo" class="mb-1 fw-bold"></h5>

                        <!-- NOME DA ONG -->
                        <div id="modalDoacaoOng" class="text-muted small"></div>

                        <!-- DESCRIÇÃO DA META -->
                        <div id="modalDoacaoDescricaoMeta" class="mt-1 small"></div>

                        <!-- ENDEREÇO -->
                        <div id="modalDoacaoEndereco" class="mt-1 small"></div>

                        <!-- VALORES DO PROGRESSO -->
                        <div id="modalDoacaoProgressoValores" class="mt-2 fw-bold"></div>

                        <!-- BARRA DE PROGRESSO -->
                        <div class="mt-3">
                            <div id="modalDoacaoProgressoTextos">
                                <small class="text-muted d-block" id="modalDoacaoProgressoValores"></small>
                                <small class="text-muted d-block" id="modalDoacaoProgressoPendente"></small>
                            </div>

                            <div class="progress modal-progresso-bar mt-2" style="height: 20px;">
                                <div id="modalDoacaoProgressoConfirmado" class="progress-bar" role="progressbar" style="width: 0%;" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100"></div>
                                <div id="modalDoacaoProgressoPendenteBar" class="progress-bar progress-bar-striped bg-info" role="progressbar" style="width: 0%;" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100"></div>
                            </div>
                        </div>
                    </div>
                </div>

                <hr class="my-4">
                <h5 class="text-center mb-3">Como deseja ajudar?</h5>

                <div class="text-center mb-4 d-flex justify-content-center">
                    <input type="radio" class="btn-check" name="tipoDoacao" id="radio-material" value="material" checked>
                    <label class="btn btn-outline-primary me-3 btn-radio-custom" for="radio-material">
                        <i class="bi bi-box-seam"></i> Quero doar material
                    </label>

                    <input type="radio" class="btn-check" name="tipoDoacao" id="radio-valor" value="valor">
                    <label class="btn btn-outline-primary btn-radio-custom" for="radio-valor">
                        <i class="bi bi-cash-coin"></i> Quero doar um valor
                    </label>
                </div>


                <div id="form-material">
                    <h5 class="text-center mb-3 fw-bold">FORMULÁRIO DE DOAÇÃO</h5>
                    <form asp-controller="Doacoes" asp-action="Create" method="post" id="form-doacao-material">

                        @Html.AntiForgeryToken()
                        <input type="hidden" id="modalDoacaoMetaId" name="MetaId" />

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="NomeCompleto" class="form-label">Nome Completo</label>
                                <input type="text" class="form-control" name="NomeCompleto" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="Email" class="form-label">E-mail</label>
                                <input type="email" class="form-control" name="Email" required>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="CPF" class="form-label">CPF</label>
                                <input type="text" class="form-control" name="CPF" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="Telefone" class="form-label">Número para contato</label>
                                <input type="tel" class="form-control" name="Telefone" required>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="Descricao" class="form-label">Descrição do que será doado</label>
                            <input type="text" class="form-control" name="Descricao" placeholder="Ex: 2 sacos de ração de 10kg" required>
                        </div>
                        <div class="mb-3">
                            <label for="Quantidade" class="form-label">Quantidade</label>
                            <input type="number" class="form-control" name="Quantidade" value="1" min="1" required>
                        </div>

                        <p class="text-center text-muted small mt-4">Após enviar o formulário você será notificado via e-mail</p>

                        <div class="text-center">
                            <button type="submit" class="btn btn-primary" style="border-radius: 20px; padding: 10px 40px;">Enviar formulário</button>
                        </div>
                    </form>
                </div>

                <div id="form-valor" style="display: none;">
                    <h5 class="text-center mb-3 fw-bold">DOAÇÃO VIA PIX</h5>
                    <div class="text-center p-3" style="background-color: #f8f9fa; border-radius: 10px;">
                        <p class="mb-2">Use a chave PIX (CNPJ) abaixo para doar qualquer valor:</p>
                        <h4 class="fw-bold" id="modalDoacaoPix" style="color: #0d6efd;"></h4>
                        <p class="text-muted small mt-2">Agradecemos de coração a sua contribuição!</p>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>


@section Scripts {
   
   <script>
      function previewImagemUnica(input, imgId) {
         if (input.files && input.files[0]) {
            var reader = new FileReader();
            reader.onload = function (e) {
               document.getElementById(imgId).src = e.target.result;
            }
            reader.readAsDataURL(input.files[0]);
         }
      }

   document.addEventListener('DOMContentLoaded', function () {
           console.log("Script Marketplace carregado.");

           const vagaModalBody = document.getElementById('vagaModalBody');
           const vagasContainer = document.getElementById('vagas-container');
           const btnDoacoes = document.getElementById('btn-toggle-doacoes');
           const btnVoluntariado = document.getElementById('btn-toggle-voluntariado');
           const metasContainer = document.getElementById('metas-container');
           const titulo = document.getElementById('resultados-titulo');
           const filtroDiasContainer = document.getElementById('filtro-dias-atuacao');
           const locationInputs = document.getElementById('location-inputs');
           const cepInput = document.getElementById('cep-input');
           const btnFiltrar = document.getElementById('btn-filtrar');


           let query = new URL(window.location.href);
           let params = query.searchParams
           let existingParams = params.get("tags")
           let existingCep = params.get("cep")    
           let tab = params.get("tab")
           let selectedTagIds = [];
           let vagasCarregadas = false;


           const resetTab = () => {
           btnDoacoes.classList.add('active');
           btnVoluntariado.classList.remove('active');
           metasContainer.style.display = 'block';
           vagasContainer.style.display = 'none';
           titulo.textContent = `Resultados para Doações (${totalMetas})`;

           }


         const changeTab = () => {
            
         document.getElementById('btn-toggle-doacoes').classList.remove('active');
         document.getElementById('btn-toggle-voluntariado').classList.add('active');
         document.getElementById('metas-container').style.display = 'none';
         document.getElementById('vagas-container').style.display = 'block';
         // document.getElementById('filtro-dias-atuacao').style.display = 'block';
         params.set("tab", "voluntariado")
         let updatedUrl = query.toString();
         // return window.location.href = updatedUrl
         if (!vagasCarregadas) {
            document.getElementById('vagas-container').innerHTML = `<div class="col-12 text-center"><p class="lead">Buscando vagas...</p></div>`;
            fetchVagas(cepInput.value, selectedTagIds);
         } else {
             document.getElementById('resultados-titulo').textContent = `Resultados para Voluntariado (${totalVagas})`;
         }
      }

           if (existingCep) {
               document.getElementById('radioEndereco').checked = true;
               document.getElementById('location-inputs').style.display = 'block';
           }

           if(existingCep) {
               const cepInput = document.getElementById("cep-input")
               cepInput.value = existingCep
           }

           if(existingParams) {
            const paramsArr = existingParams.split(",")
            selectedTagIds = paramsArr
            paramsArr.map(id =>
                document.getElementById(id).classList.add("active")
            )

            if(tab) {
               changeTab()
           }
        }

           
           window.toggleTag = function (button) {
               const id = button.id;

               if (button.classList.contains('active')) {
                   // se já estava ativa, desmarca
                   button.classList.remove('active');
                   selectedTagIds = selectedTagIds.filter(id => id !== button.id)
                   console.log(selectedTagIds)
               } else {
                   // se não estava ativa, marca
                   button.classList.add('active');
                   console.log(selectedTagIds)
                   selectedTagIds.push(id);
               }

               console.log('Tags selecionadas:', Array.from(selectedTagIds));
           };
  
      window.conectarFormularioInscricao = function () {
         const formInscricao = document.getElementById('formInscricaoVaga');

         if (formInscricao) {
            console.log("Formulário de inscrição encontrado! Conectando listener de submit...");

            
            const novoForm = formInscricao.cloneNode(true);
            formInscricao.parentNode.replaceChild(novoForm, formInscricao);

            novoForm.addEventListener('submit', async function (event) {
               
               event.preventDefault();
               console.log("Envio interceptado pelo JavaScript!");

               const form = event.target;
               const submitButton = form.querySelector('.btn-submit-vaga');

               if (submitButton) {
                  submitButton.disabled = true;
                  submitButton.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Enviando...';
               }

               try {
                  const formData = new FormData(form);

                  const response = await fetch(form.action, {
                     method: 'POST',
                     body: formData
                  });

                  if (response.ok) {
                     console.log("Sucesso! Atualizando modal para mensagem de confirmação.");
                     const vagaModalBody = document.getElementById('vagaModalBody');
                     if (vagaModalBody) {
                        vagaModalBody.innerHTML = `
                                        <div class="text-center py-5 fade-in">
                                            <div class="mb-4">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="90" height="90" fill="#198754" class="bi bi-check-circle-fill" viewBox="0 0 16 16">
                                                    <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
                                                </svg>
                                            </div>
                                            <h3 class="text-success fw-bold mb-3">Inscrição Realizada!</h3>
                                            <p class="text-muted fs-5">Seus dados foram enviados para a ONG.</p>
                                            <p class="text-muted small mb-4">Verifique seu e-mail para a confirmação.</p>
                                            <button type="button" class="btn btn-secondary px-5 py-2 rounded-pill" data-bs-dismiss="modal">Fechar</button>
                                        </div>
                                    `;
                     }
                  } else {
                     console.log("Erro de validação. Recarregando formulário com erros.");
                     const html = await response.text();
                     const vagaModalBody = document.getElementById('vagaModalBody');
                     if (vagaModalBody) {
                        vagaModalBody.innerHTML = html;
                        
                        window.conectarFormularioInscricao();
                     }
                  }

               } catch (error) {
                  console.error('Erro de conexão:', error);
                  const vagaModalBody = document.getElementById('vagaModalBody');
                  if (vagaModalBody) {
                     vagaModalBody.innerHTML = '<div class="alert alert-danger">Ocorreu um erro de conexão. Tente novamente.</div><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Fechar</button>';
                  }
               }
            });
         } else {
            console.warn("Formulário 'formInscricaoVaga' não encontrado dentro do modal.");
         }
      };

      // --- LÓGICA DO MODAL DE VAGA ---
      const vagaModalElement = document.getElementById('vagaModal');
      let vagaModal;
      if (vagaModalElement && typeof bootstrap !== 'undefined') {
         vagaModal = new bootstrap.Modal(vagaModalElement);
      }

      // Toggle Doações/Vagas
      
      let totalMetas = @Model.Count();
      let totalVagas = 0;

      btnDoacoes.addEventListener('click', function () {
         resetTab()
         params.delete("tab")
         let updatedUrl = query.toString();
         // return window.location.href = updatedUrl
      });

      btnVoluntariado.addEventListener('click', function () {
         changeTab()
      });

      window.toggleLocationInputs = function (show) {
         locationInputs.style.display = show ? 'block' : 'none';
         if (show) document.getElementById('radioEndereco').checked = true;
      }

      // Filtros
      btnFiltrar.addEventListener('click', function () {
         const cep = cepInput.value; 

         if (cep) {
                params.set("cep", cep)
            }
            else params.delete("cep")

            if(selectedTagIds.length > 0){
                params.set("tags", selectedTagIds)
            } 
            else params.delete("tags")

         if(btnDoacoes.classList.contains('active')) {
             params.delete("tab")
             let updatedUrl = query.toString();
             return window.location.href = updatedUrl
         }

         if (btnVoluntariado.classList.contains('active')) {
            vagasContainer.innerHTML = `<div class="col-12 text-center"><p class="lead">Buscando vagas filtradas...</p></div>`;
            titulo.textContent = 'Resultados para Voluntariado (0)';
            fetchVagas(cep, selectedTagIds);

         } 
            let updatedUrl = query.toString();
            return window.location.href = updatedUrl
         
      });

      function fetchVagas(cep = '', tags = []) {
           
         vagasCarregadas = false;
         let url = new URL('@Url.Action("GetVagasPartial", "Home")', window.location.origin);
         if(tags.length) url.searchParams.append('tags', tags)
         if (cep) url.searchParams.append('cep', cep);
         fetch(url.toString())
            .then(response => {
               if (!response.ok) throw new Error('Falha ao buscar vagas.');
               return response.text();
            })
            .then(html => {
               vagasContainer.innerHTML = `<div class="row">${html}</div>`;
               vagasCarregadas = true;
               totalVagas = vagasContainer.querySelectorAll('.card-item-vaga').length;
               titulo.textContent = `Resultados para Voluntariado (${totalVagas})`;
            })
            .catch(error => {
               console.error('Erro no AJAX:', error);
               vagasContainer.innerHTML = `<div class="col-12 text-center"><p class="lead text-danger">Erro ao carregar vagas.</p></div>`;
            });
      }

      // CEP Input Mask
      cepInput.addEventListener('input', function (e) {
         let v = e.target.value.replace(/\D/g, '');
         v = v.replace(/^(\d{5})(\d)/, '$1-$2');
         e.target.value = v.slice(0, 9);
      });
      cepInput.addEventListener('blur', async function () {
         const cep = this.value.replace(/\D/g, ''); 
      });

      // 1. Abrir o modal e carregar o formulário
      if (vagasContainer) {
         vagasContainer.addEventListener('click', function (event) {
            const target = event.target.closest('.btn-visualizar');
            if (target) {
               event.preventDefault();
               const vagaId = target.dataset.vagaId;

               if (vagaModal) vagaModal.show();

               vagaModalBody.innerHTML = `
                            <div class="text-center p-5">
                                <div class="spinner-border text-primary" role="status"></div>
                                <p class="mt-2 text-muted">Carregando informações...</p>
                            </div>`;

               fetch(`@Url.Action("GetVagaDetalheFormPartial", "Home")?vagaId=${vagaId}`)
                  .then(response => response.text())
                  .then(html => {
                     vagaModalBody.innerHTML = html;
                     // --- AQUI A MÁGICA ACONTECE ---
                     // Chamamos a função para conectar o listener assim que o HTML novo é inserido
                     window.conectarFormularioInscricao();
                  })
                  .catch(error => {
                     vagaModalBody.innerHTML = `<div class="alert alert-danger">Erro ao carregar vaga.</div>`;
                  });
            }
         });
      }


      // Modal Doação
      const doacaoModalElement = document.getElementById('modalDoacao');
      let doacaoModal;
      const radioMaterial = document.getElementById('radio-material');
      const radioValor = document.getElementById('radio-valor');
      const formMaterial = document.getElementById('form-material');
      const formValor = document.getElementById('form-valor');
      const campoPix = document.getElementById('modalDoacaoPix');

      if (doacaoModalElement && typeof bootstrap !== 'undefined') {
         doacaoModal = new bootstrap.Modal(doacaoModalElement);
      }

      if (radioMaterial && radioValor && formMaterial && formValor) {
         radioMaterial.addEventListener('change', function () {
            if (this.checked) {
               formMaterial.style.display = 'block';
               formValor.style.display = 'none';
            }
         });
         radioValor.addEventListener('change', function () {
            if (this.checked) {
               formMaterial.style.display = 'none';
               formValor.style.display = 'block';
            }
         });
      }

      const BotoesDoar = document.querySelectorAll('.abrirModalDoacaoBtn');
      BotoesDoar.forEach(button => {
         button.addEventListener('click', function (e) {
            e.preventDefault();
            const btn = this;
            const metaId = btn.dataset.metaId;
            const titulo = btn.dataset.titulo;
            const ong = btn.dataset.ong;
            const descricao = btn.dataset.descricao;
            const endereco = btn.dataset.endereco;
            const imagem = btn.dataset.imagem;
            const atual = parseFloat(btn.dataset.atual);
            const alvo = parseFloat(btn.dataset.alvo);
            const ongCnpj = btn.dataset.ongCnpj;

            const valorConfirmado = atual;
            const valorAlvo = alvo;
            const valorPendente = 0;
            let percConfirmado = (valorAlvo > 0) ? (valorConfirmado / valorAlvo) * 100 : 0;
            let percPendente = (valorAlvo > 0) ? (valorPendente / valorAlvo) * 100 : 0;
            if (percConfirmado + percPendente > 100) percPendente = 100 - percConfirmado;

            const progressoConfirmadoF = percConfirmado.toFixed(0) + '%';
            const progressoPendenteF = percPendente.toFixed(0) + '%';
            const progressoValoresTexto = `${valorConfirmado} de ${valorAlvo}`;

            doacaoModalElement.querySelector('#modalDoacaoLogo').src = imagem || '';
            doacaoModalElement.querySelector('#modalDoacaoTitulo').textContent = titulo;
            doacaoModalElement.querySelector('#modalDoacaoOng').textContent = ong;
            doacaoModalElement.querySelector('#modalDoacaoDescricaoMeta').textContent = descricao;
            doacaoModalElement.querySelector('#modalDoacaoEndereco').textContent = endereco;
            doacaoModalElement.querySelector('#modalDoacaoProgressoValores').textContent = progressoValoresTexto;

            const progressoBarConfirmada = doacaoModalElement.querySelector('#modalDoacaoProgressoConfirmado');
            progressoBarConfirmada.style.width = progressoConfirmadoF;
            progressoBarConfirmada.textContent = progressoConfirmadoF;

            const progressoBarPendente = doacaoModalElement.querySelector('#modalDoacaoProgressoPendenteBar');
            const pendenteTextElement = doacaoModalElement.querySelector('#modalDoacaoProgressoPendente');
            progressoBarPendente.style.width = progressoPendenteF;
            if (valorPendente > 0) pendenteTextElement.textContent = `(${valorPendente} pendentes de aprovação)`;
            else pendenteTextElement.textContent = '';

            doacaoModalElement.querySelector('#modalDoacaoMetaId').value = metaId;
            if (campoPix) campoPix.textContent = ongCnpj || "Chave PIX não informada";

            if (radioMaterial) radioMaterial.checked = true;
            if (formMaterial) formMaterial.style.display = 'block';
            if (formValor) formValor.style.display = 'none';

            if (doacaoModal) doacaoModal.show();
         });
      });

      const formDoacao = document.getElementById('form-doacao-material');
      if (formDoacao) {
         formDoacao.addEventListener('submit', async function (e) {
            e.preventDefault();
            const form = e.target;
            const submitButton = form.querySelector('button[type="submit"]');
            const originalButtonText = submitButton.textContent;
            submitButton.disabled = true;
            submitButton.innerHTML = `<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Enviando...`;

            try {
               const formData = new FormData(form);
               const token = formData.get('__RequestVerificationToken');
               const response = await fetch(form.action, {
                  method: 'POST',
                  body: formData,
                  headers: {
                     'RequestVerificationToken': token
                  }
               });
               const result = await response.json();
               if (result.success) {
                  if (doacaoModal) doacaoModal.hide();
                  alert(result.message);
               } else {
                  alert('Erro: ' + result.message);
               }
            } catch (error) {
               console.error('Erro no fetch:', error);
               alert('Ocorreu um erro de rede. Tente novamente.');
            } finally {
               submitButton.disabled = false;
               submitButton.textContent = originalButtonText;
            }
         });
      }
   }); 
   </script>
}